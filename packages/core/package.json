{
  "name": "@mcpfinder/core",
  "version": "1.0.0",
  "description": "Core library for MCPfinder: multi-registry sync (Official, Glama, Smithery), SQLite+FTS5 ranked search, and install config generation.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lksrz/mcpfinder.git",
    "directory": "packages/core"
  },
  "homepage": "https://mcpfinder.dev",
  "bugs": { "url": "https://github.com/lksrz/mcpfinder/issues" },
  "engines": { "node": ">=20" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Coder AI <hello@coderai.dev>",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
